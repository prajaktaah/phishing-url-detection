{
  "manifest_version": 3,
  "name": "PhishPhry URL Detector",
  "version": "1.0",
  "description": "Tracks malicious URLs and displays a security dashboard",

  "permissions": [
    "tabs",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_title": "PhishPhry URL Detector",
    "default_icon": {
      "16": "new16.png",
      "32": "new32.png",
      "48": "new48.png",
      "128": "new128.png"
    }
  },

  "icons": {
      "16": "new16.png",
      "32": "new32.png",
      "48": "new48.png",
      "128": "new128.png"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["cursor.js", "content.js"],
      "css": ["tooltip.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "cursor64.png",
        "puff64.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
